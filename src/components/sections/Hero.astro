---
import Section from '../layout/Section.astro';
import Container from '../layout/Container.astro';
import Heading from '../ui/Heading.astro';
import Text from '../ui/Text.astro';
import Grid from '../layout/Grid.astro';
import Button from '../ui/Button.astro';
import ArrowRightIcon from '../ui/ArrowRightIcon.astro';
import GithubIcon from '../ui/GitHubIcon.astro';
import LinkedInIcon from '../ui/LinkedInIcon.astro';

const name = 'Daniel Derudder';
const jobTitle = 'Développeur';
const jobTitle2 = 'Full Stack Typescript';
const description =
  'Développeur full stack trilingue (FR - NL - EN) basé à Paris. Je crée des applications web et sites internet.';
---

<Section class="hero">
  <Container>
    <Grid class="hero-grid">
      <Heading level={1} class="hero-name">{name}</Heading>

      <div class="hero-content">
        <Heading level={2} class="hero-job-title">
          <span class="hero-job-title-1">{jobTitle}</span><br />
          <span class="hero-job-title-2">{jobTitle2}</span>
        </Heading>

        <Text class="hero-description">
          {description}
        </Text>
      </div>

      <div class="hero-actions">
        <Button variant="primary" class="hero-button button-cta">
          Télécharger mon CV <ArrowRightIcon size={24} />
        </Button>
        <Button
          variant="secondary"
          class="hero-button button-icon button-icon-github"
        ><GithubIcon /></Button>
        <Button
          variant="secondary"
          class="hero-button button-icon button-icon-linkedin"
        ><LinkedInIcon /></Button>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <svg class="hero-mesh" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid slice">
          <g class="hero-mesh__faces"></g>
          <g class="hero-mesh__edges"></g>
          <g class="hero-mesh__vertices"></g>
        </svg>
      </div>
    </Grid>
  </Container>
</Section>

<style>
  .hero {
    min-height: calc(100svh - (var(--nav-height) + 1px));
    display: flex;
  }

  .hero-grid {
    min-height: calc(
      100svh - (var(--nav-height) + 1px) - (var(--space-lg) * 2)
    );
    grid-template-rows: auto 1fr auto;
  }

  /* --- Row 1: Name eyebrow --- */

  .hero-name {
    grid-row: 1;
    grid-column: 1 / 8;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-light);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  /* --- Row 2: Title + description (grouped) --- */

  .hero-content {
    grid-row: 2;
    grid-column: 1 / 8;
    align-self: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .hero-job-title {
    font-size: var(--font-size-hero);
    font-weight: var(--font-weight-normal);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .hero-description {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-light);
    line-height: 1.4;
    max-width: 36ch;
  }

  /* --- Row 3: CTA + social icons --- */

  .hero-actions {
    grid-row: 3;
    grid-column: 1 / 7;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .button-cta {
    padding-block: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    font-size: var(--font-size-base);
  }

  .button-cta :global(svg) {
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .button-cta:hover :global(svg) {
    transform: translateX(4px);
  }

  /* --- Right: Visual element area --- */

  .hero-visual {
    grid-row: 1 / -1;
    grid-column: 8 / -1;
    position: relative;
    overflow: hidden;
    color: var(--color-primary);
  }

  .hero-mesh {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  function initHeroMesh() {
    const svg = document.querySelector<SVGSVGElement>('.hero-mesh');
    if (!svg || svg.dataset.initialized) return;
    svg.dataset.initialized = 'true';

    const ns = 'http://www.w3.org/2000/svg';
    const facesG = svg.querySelector('.hero-mesh__faces')!;
    const edgesG = svg.querySelector('.hero-mesh__edges')!;
    const verticesG = svg.querySelector('.hero-mesh__vertices')!;
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    const THRESHOLD = 160;
    const INNER = THRESHOLD * 0.6;
    const DRIFT = 20;
    const SPEED = 0.00012;

    const homes = [
      { x: 60, y: 40 },
      { x: 230, y: 50 },
      { x: 360, y: 30 },
      { x: 30, y: 160 },
      { x: 170, y: 145 },
      { x: 320, y: 155 },
      { x: 90, y: 270 },
      { x: 240, y: 260 },
      { x: 370, y: 275 },
      { x: 40, y: 380 },
      { x: 190, y: 370 },
      { x: 340, y: 385 },
      { x: 100, y: 480 },
      { x: 260, y: 490 },
      { x: 380, y: 475 },
      { x: 170, y: 570 },
    ];

    const triIdx = [
      [3, 4, 6],
      [4, 5, 7],
      [6, 7, 10],
      [9, 10, 12],
    ];

    const vp = homes.map((_, i) => ({
      px: (((i * 137.508) % 360) * Math.PI) / 180,
      py: (((i * 97.135) % 360) * Math.PI) / 180,
      fx: 0.7 + ((i * 31) % 10) * 0.06,
      fy: 0.7 + ((i * 47) % 10) * 0.06,
    }));

    const dots = homes.map((h) => {
      const c = document.createElementNS(ns, 'circle');
      c.setAttribute('r', '1.5');
      c.setAttribute('fill', 'currentColor');
      c.setAttribute('opacity', '0.2');
      c.setAttribute('cx', String(h.x));
      c.setAttribute('cy', String(h.y));
      verticesG.appendChild(c);
      return c;
    });

    const strongPath = document.createElementNS(ns, 'path');
    strongPath.setAttribute('stroke', 'currentColor');
    strongPath.setAttribute('stroke-width', '0.5');
    strongPath.setAttribute('opacity', '0.12');
    strongPath.setAttribute('fill', 'none');
    edgesG.appendChild(strongPath);

    const weakPath = document.createElementNS(ns, 'path');
    weakPath.setAttribute('stroke', 'currentColor');
    weakPath.setAttribute('stroke-width', '0.5');
    weakPath.setAttribute('opacity', '0.05');
    weakPath.setAttribute('fill', 'none');
    edgesG.appendChild(weakPath);

    const faceEls = triIdx.map(() => {
      const p = document.createElementNS(ns, 'polygon');
      p.setAttribute('fill', 'currentColor');
      p.setAttribute('opacity', '0');
      facesG.appendChild(p);
      return p;
    });

    const cur = homes.map((h) => ({ x: h.x, y: h.y }));
    let lastFrame = 0;

    function tick(time: number) {
      if (!reducedMotion && time - lastFrame < 50) {
        requestAnimationFrame(tick);
        return;
      }
      lastFrame = time;

      const t = time * SPEED;

      for (let i = 0; i < homes.length; i++) {
        cur[i].x =
          homes[i].x + Math.sin(t * vp[i].fx + vp[i].px) * DRIFT;
        cur[i].y =
          homes[i].y + Math.cos(t * vp[i].fy + vp[i].py) * DRIFT;
        dots[i].setAttribute('cx', cur[i].x.toFixed(1));
        dots[i].setAttribute('cy', cur[i].y.toFixed(1));
      }

      let sd = '';
      let wd = '';
      for (let i = 0; i < cur.length; i++) {
        for (let j = i + 1; j < cur.length; j++) {
          const dx = cur[i].x - cur[j].x;
          const dy = cur[i].y - cur[j].y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < INNER) {
            sd += `M${cur[i].x.toFixed(1)} ${cur[i].y.toFixed(1)}L${cur[j].x.toFixed(1)} ${cur[j].y.toFixed(1)}`;
          } else if (d < THRESHOLD) {
            wd += `M${cur[i].x.toFixed(1)} ${cur[i].y.toFixed(1)}L${cur[j].x.toFixed(1)} ${cur[j].y.toFixed(1)}`;
          }
        }
      }
      strongPath.setAttribute('d', sd || 'M0 0');
      weakPath.setAttribute('d', wd || 'M0 0');

      for (let k = 0; k < triIdx.length; k++) {
        const [a, b, c] = triIdx[k];
        const dAB = Math.sqrt(
          (cur[a].x - cur[b].x) ** 2 + (cur[a].y - cur[b].y) ** 2,
        );
        const dBC = Math.sqrt(
          (cur[b].x - cur[c].x) ** 2 + (cur[b].y - cur[c].y) ** 2,
        );
        const dAC = Math.sqrt(
          (cur[a].x - cur[c].x) ** 2 + (cur[a].y - cur[c].y) ** 2,
        );
        const maxD = Math.max(dAB, dBC, dAC);
        const fo =
          maxD < THRESHOLD
            ? 0.04 * (1 - maxD / THRESHOLD) ** 2
            : 0;
        faceEls[k].setAttribute('opacity', fo.toFixed(4));
        faceEls[k].setAttribute(
          'points',
          `${cur[a].x.toFixed(1)},${cur[a].y.toFixed(1)} ${cur[b].x.toFixed(1)},${cur[b].y.toFixed(1)} ${cur[c].x.toFixed(1)},${cur[c].y.toFixed(1)}`,
        );
      }

      if (!reducedMotion) {
        requestAnimationFrame(tick);
      }
    }

    if (reducedMotion) {
      tick(0);
    } else {
      requestAnimationFrame(tick);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroMesh);
  } else {
    initHeroMesh();
  }
  document.addEventListener('astro:page-load', initHeroMesh);
</script>
