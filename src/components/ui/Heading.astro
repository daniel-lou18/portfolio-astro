---
import type { HTMLAttributes } from 'astro/types';

type HeadingProps = HTMLAttributes<'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'> & {
  level?: 1 | 2 | 3 | 4 | 5 | 6;
};

const {
  level = 1,
  class: className = '',
  ...attrs
}: HeadingProps = Astro.props;

const Tag = `h${level}`;
---

<Tag class:list={[`heading heading-${level} ${className}`]} {...attrs}>
  <slot />
</Tag>
