---
import '../../styles/global.css';

const {
  className = '',
  tone = 'neutral',
  variant = 'soft',
  size = 'md',
  rounded = true,
  href,
  title,
  ariaLabel,
} = Astro.props as {
  className?: string;
  tone?: 'neutral' | 'primary' | 'success' | 'warning' | 'danger';
  variant?: 'soft' | 'outline' | 'solid';
  size?: 'sm' | 'md' | 'lg';
  rounded?: boolean;
  href?: string;
  title?: string;
  ariaLabel?: string;
};

const Tag = (href ? 'a' : 'span') as any;
const attrs = href
  ? ({
      href,
      title,
      'aria-label': ariaLabel,
      target: '_blank',
      rel: 'noopener noreferrer',
    } as Record<string, string>)
  : ({ title, 'aria-label': ariaLabel } as Record<string, string>);

const badgeClass = [
  'badge',
  `badge--tone-${tone}`,
  `badge--variant-${variant}`,
  `badge--size-${size}`,
  rounded ? 'badge--rounded' : 'badge--square',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Tag class={badgeClass} {...attrs}>
  <slot />
</Tag>

<style>
  .badge {
    --tone-fg: #111827;
    --tone-fg-solid: #f9fafb;
    --tone-bg-soft: #f3f4f6;
    --tone-border-soft: #e5e7eb;
    --tone-border-outline: #d1d5db;
    --tone-bg-solid: #111827;

    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;

    white-space: nowrap;
    vertical-align: middle;
    text-decoration: none;
    user-select: none;

    border: 1px solid transparent;
    border-radius: 0.5rem;

    font-family: inherit;
    line-height: 1;

    background: transparent;
    color: var(--tone-fg);
    padding: 0.25rem 0.5rem;
    font-size: 0.875rem;
  }

  .badge--rounded {
    border-radius: 9999px;
  }

  .badge--square {
    border-radius: 0.5rem;
  }

  .badge--size-sm {
    padding: 0.125rem 0.375rem;
    font-size: 0.75rem;
  }

  .badge--size-lg {
    padding: 0.375rem 0.75rem;
    font-size: 1rem;
  }

  .badge--variant-soft {
    background: var(--tone-bg-soft);
    border-color: var(--tone-border-soft);
    color: var(--tone-fg);
  }

  .badge--variant-outline {
    background: transparent;
    border-color: var(--tone-border-outline);
    color: var(--tone-fg);
  }

  .badge--variant-solid {
    background: var(--tone-bg-solid);
    border-color: transparent;
    color: var(--tone-fg-solid);
  }

  .badge--tone-neutral {
    --tone-bg-soft: #f3f4f6;
    --tone-border-soft: #e5e7eb;
    --tone-border-outline: #d1d5db;
    --tone-fg: #111827;
    --tone-bg-solid: #111827;
    --tone-fg-solid: #f9fafb;
  }

  .badge--tone-primary {
    --tone-bg-soft: #dbeafe;
    --tone-border-soft: #bfdbfe;
    --tone-border-outline: #60a5fa;
    --tone-fg: #1d4ed8;
    --tone-bg-solid: #2563eb;
    --tone-fg-solid: #ffffff;
  }

  .badge--tone-success {
    --tone-bg-soft: #dcfce7;
    --tone-border-soft: #bbf7d0;
    --tone-border-outline: #4ade80;
    --tone-fg: #166534;
    --tone-bg-solid: #16a34a;
    --tone-fg-solid: #ffffff;
  }

  .badge--tone-warning {
    --tone-bg-soft: #fef9c3;
    --tone-border-soft: #fef08a;
    --tone-border-outline: #f59e0b;
    --tone-fg: #854d0e;
    --tone-bg-solid: #d97706;
    --tone-fg-solid: #ffffff;
  }

  .badge--tone-danger {
    --tone-bg-soft: #fee2e2;
    --tone-border-soft: #fecaca;
    --tone-border-outline: #ef4444;
    --tone-fg: #991b1b;
    --tone-bg-solid: #dc2626;
    --tone-fg-solid: #ffffff;
  }
</style>
