---
import type { HTMLAttributes } from 'astro/types';

type GitHubIconProps = HTMLAttributes<'svg'> & {
  size?: number;
  ariaLabel?: string;
};

const {
  class: className = '',
  size = 28,
  ariaLabel,
  ...attrs
}: GitHubIconProps = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  focusable="false"
  class={className}
  role={ariaLabel ? 'img' : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : 'true'}
  {...attrs}
