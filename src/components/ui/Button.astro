---
import type { HTMLAttributes } from 'astro/types';

type Variant = 'primary' | 'secondary' | 'tertiary' | 'link' | 'rounded';
type ButtonProps = HTMLAttributes<'button'> & {
  variant?: Variant;
};

const {
  class: className = '',
  variant = 'primary',
  ...attrs
}: ButtonProps = Astro.props;

const variantClass: Record<Variant, string> = {
  primary: 'button-primary',
  secondary: 'button-secondary',
  tertiary: 'button-tertiary',
  link: 'button-link',
  rounded: 'button-rounded',
};
---

<button
  class:list={[`button ${variantClass[variant as Variant]} ${className}`]}
  {...attrs}
>
  <slot />
</button>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--border-radius-md);
    border-width: 1px;
    border-style: solid;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  :global(.button-primary) {
    background-color: var(--color-primary);
    color: var(--color-secondary);
    border-color: var(--color-primary);
    &:hover {
      background-color: var(--color-primary-hover);
    }
  }
  :global(.button-secondary) {
    background-color: var(--color-secondary);
    color: var(--color-primary);
    border-color: var(--color-primary);
    &:hover {
      background-color: var(--color-secondary-hover);
    }
  }
  :global(.button-tertiary) {
    background-color: var(--color-tertiary);
    color: var(--color-primary);
    border-color: var(--color-tertiary);
    &:hover {
      background-color: var(--color-tertiary-hover);
    }
  }
  :global(.button-link) {
    background-color: var(--color-link);
    color: var(--color-primary);
    border-color: var(--color-link);
    &:hover {
      background-color: var(--color-link-hover);
    }
  }
  .button:global(.button-rounded) {
    border-radius: var(--border-radius-rounded);
  }
  .button:global(.button-icon) {
    --button-icon-size: 3rem;
    padding: 0;
    width: var(--button-icon-size);
    height: var(--button-icon-size);
    gap: 0;
    justify-content: center;
    align-items: center;
    justify-self: center;
    align-self: center;
    flex: 0 0 auto;
    border-radius: 50%;
    border-color: var(--color-primary);
    background-color: transparent;
  }

  .button:global(.button-icon):hover {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-secondary);
  }

  .button:global(.button-icon) :global(svg) {
    width: 55%;
    height: 55%;
    display: block;
    flex: 0 0 auto;
  }

  .button:global(.button-icon) :global(path) {
    fill: currentColor;
    fill-opacity: 0;
    stroke: currentColor;
    stroke-width: 0.75;
    transition:
      fill-opacity 0.3s ease,
      stroke-width 0.3s ease;
  }

  .button:global(.button-icon):hover :global(path) {
    fill-opacity: 1;
    stroke-width: 0;
  }
</style>
