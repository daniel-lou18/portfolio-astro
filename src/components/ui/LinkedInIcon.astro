---
import type { HTMLAttributes } from 'astro/types';

type LinkedInIconProps = HTMLAttributes<'svg'> & {
  size?: number;
  ariaLabel?: string;
};

const {
  class: className = '',
  size = 20,
  ariaLabel,
  ...attrs
}: LinkedInIconProps = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  focusable="false"
  class={className}
  role={ariaLabel ? 'img' : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : 'true'}
  {...attrs}
